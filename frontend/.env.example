# ── Supabase Configuration (Shared Development Database) ──────────
# Database sudah tersedia — TIDAK perlu membuat project Supabase sendiri.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# ── Backend API ───────────────────────────────────────────────────
VITE_API_URL="http://localhost:5003/api"
VITE_API_PROXY="http://localhost:5003"

# ── Blockchain Configuration ─────────────────────────────────────
# Alamat wallet merchant (Hardhat Account #1) untuk menerima pembayaran ETH
VITE_MERCHANT_ETH_ADDRESS="PRIVATEKEY KAMU"

# Set 'true' untuk Hardhat local network, 'false' untuk Sepolia testnet
VITE_USE_LOCALNET="true"

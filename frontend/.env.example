# ── Supabase Configuration ─────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Backend API ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:5003/api
VITE_API_PROXY=http://localhost:5003

# ── Blockchain Configuration ─────────────────────────────────────
# Merchant wallet address (for receiving ETH payments)
VITE_MERCHANT_ETH_ADDRESS=0xYOUR_MERCHANT_WALLET_ADDRESS

# Set to 'true' to use local Hardhat network, 'false' for Sepolia testnet
VITE_USE_LOCALNET=true
